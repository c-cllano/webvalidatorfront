{
    "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
    "version": 1,
    "newProjectRoot": "projects",
    "projects": {
        "webflow": {
            "projectType": "application",
            "schematics": {},
            "root": "",
            "sourceRoot": "src",
            "prefix": "app",
            "architect": {
                "build": {
                    "builder": "@angular-devkit/build-angular:application",
                    "options": {
                     "baseHref": "/webflow/",
                      "outputPath": "dist/webflow",
                      "index": "src/index.html",
                      "browser": "src/main.ts",
                      "polyfills": [
                        "zone.js"
                      ],
                      "tsConfig": "tsconfig.app.json",
                      "assets": [
                        {
                          "glob": "**/*",
                          "input": "public"
                        }
                      ],
                      "styles": [
                         "node_modules/ngx-spinner/animations/ball-spin.css",
                        "src/styles.css"
                      ],
                      "scripts": [],
                      "server": "src/main.server.ts",
                      "prerender": true,
                      "ssr": {
                        "entry": "server.ts"
                      }
                    },
                    "configurations": {
                        "production": {
                            "budgets": [{
                                    "type": "initial",
                                    "maximumWarning": "5MB",
                                    "maximumError": "5MB"
                                },
                                {
                                    "type": "anyComponentStyle",
                                    "maximumWarning": "5kB",
                                    "maximumError": "10kB"
                                }
                            ],
                            "outputHashing": "all",
                            "serviceWorker": "ngsw-config.json"
                        },
                        "development": {
                            "optimization": false,
                            "extractLicenses": false,
                            "sourceMap": true,
                            "fileReplacements": [
                              {
                                "replace": "src/environments/environment.ts",
                                "with": "src/environments/environment.development.ts"
                              }
                            ]
                        }
                    },
                    "defaultConfiguration": "production"
                },
                "serve": {
                    "builder": "@angular-devkit/build-angular:dev-server",
                    "configurations": {
                        "production": {
                            "buildTarget": "webflow:build:production"
                        },
                        "development": {
                            "buildTarget": "webflow:build:development"
                        }
                    },
                    "defaultConfiguration": "development"
                },
                "extract-i18n": {
                    "builder": "@angular-devkit/build-angular:extract-i18n"
                },
                "test": {
                    "builder": "@angular-devkit/build-angular:karma",
                    "options": {
                        "polyfills": [
                            "zone.js",
                            "zone.js/testing"
                        ],
                        "tsConfig": "tsconfig.spec.json",
                        "assets": [{
                            "glob": "**/*",
                            "input": "public"
                        }],
                        "styles": [

                            "src/styles.css"
                        ],
                        "scripts": [

                        ]
                    }
                }
            }
        }
    },
    "cli": {
        "analytics": "8d965c09-6eb2-42ed-a469-1e90d9c32d3d",
        "cache": {
            "enabled": true,
            "path": ".cache",
            "environment": "all"
        }
    }

}